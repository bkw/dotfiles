#!/bin/bash

set -euo pipefail

export VOLTA_HOME="${XDG_DATA_HOME:-{{ .chezmoi.homeDir }}/.local/share}/volta"

# Ensure volta is available — install if not
if ! command -v volta &>/dev/null && ! [[ -x "$VOLTA_HOME/bin/volta" ]]; then
  echo "Installing volta..."
  curl https://get.volta.sh | bash -s -- --skip-setup
fi
