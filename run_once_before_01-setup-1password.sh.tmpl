#!/bin/bash

set -euo pipefail

if ! command -v op &>/dev/null; then
  echo "1Password CLI (op) is not installed. Skipping account setup."
  echo "Install it from https://developer.1password.com/docs/cli/get-started/"
  exit 0
fi

if op account list --format=json 2>/dev/null | grep -q "{{ .opAccount }}"; then
  echo "1Password account {{ .opAccount }} is already configured."
  exit 0
fi

echo "Adding 1Password account {{ .opAccount }}..."
echo "You will be prompted for your secret key and password."
op account add \
  --address "{{ .opAccount }}" \
  --email "{{ .opEmail }}"

echo "1Password account configured successfully."
echo "Re-running chezmoi init to populate config from 1Password..."
chezmoi init
