# zshrc (interactive shells)

if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]
fi

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Do not share history between screen tabs:
unsetopt sharehistory

alias -- +x='chmod +x'
alias vim=nvim

# Google Cloud
# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/bkw/code/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/bkw/code/google-cloud-sdk/path.zsh.inc'; fi
if [ -f '/Users/bkw/code/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/bkw/code/google-cloud-sdk/completion.zsh.inc'; fi

# source /Users/bkw/.config/broot/launcher/bash/br

alias curl='noglob curl'
alias youtube-dl='noglob youtube-dl'

# intel homebrew:
alias brow='arch --x86_64 /usr/local/Homebrew/bin/brew'

# 1password https://developer.1password.com/docs/cli/get-started/#shell-completion
eval "$(op completion zsh)"; compdef _op op
source ${XDG_CONFIG_HOME}/op/plugins.sh

