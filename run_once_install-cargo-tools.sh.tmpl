#!/bin/bash

set -euo pipefail

export CARGO_HOME="${XDG_DATA_HOME:-{{ .chezmoi.homeDir }}/.local/share}/cargo"

# Ensure cargo is available — install via rustup if not
if ! command -v cargo &>/dev/null && ! [[ -x "$CARGO_HOME/bin/cargo" ]]; then
  echo "Installing rustup..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
fi

RUSTUP="$(command -v rustup 2>/dev/null || echo "$CARGO_HOME/../rustup/bin/rustup")"
if [[ -x "$RUSTUP" ]]; then
  echo "Updating rust toolchain..."
  "$RUSTUP" update stable --no-self-update
fi

CARGO="$(command -v cargo 2>/dev/null || echo "$CARGO_HOME/bin/cargo")"

echo "Installing cargo tools..."
"$CARGO" install tree-sitter-cli
